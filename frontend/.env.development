# 开发环境配置

# API 基础地址（根据后端实际运行端口修改）
# 如果后端运行在8000端口，改为: http://localhost:8000/api
# 如果后端运行在8080端口，改为: http://localhost:8080/api
VITE_API_BASE_URL=http://localhost:8000/api

# 基础路径
VITE_BASE_PATH=/

# 应用标题
VITE_APP_TITLE=太初命理(开发版)

# 是否开启调试
VITE_DEBUG=true

# 本地测试验证码（与后端 SMS_TEST_CODE 保持一致）
VITE_TEST_SMS_CODE=123456
