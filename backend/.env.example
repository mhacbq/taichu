# 应用配置
APP_DEBUG = true
APP_TRACE = false
APP_HOST = 

# 数据库配置
DB_DRIVER = mysql
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = taichu
DB_USER = root
DB_PASSWORD = 
DB_CHARSET = utf8mb4
DB_PREFIX = tc_

# JWT配置 - 请使用强密钥，生成命令: openssl rand -base64 32
# 生产环境必须设置此值，且长度不少于32个字符
JWT_SECRET = 
JWT_ISSUER = taichu-api
JWT_AUDIENCE = taichu-app

# 日志配置
LOG_LEVEL = info
LOG_PATH = runtime/log

# API安全配置
API_SIGN_KEY = change-this-key-in-production
REPLAY_PROTECTION_ENABLED = true

# 缓存配置
CACHE_DRIVER = file
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD = 
