# 应用配置
APP_DEBUG = true
APP_TRACE = false
APP_HOST = 

# 数据库配置
DB_DRIVER = mysql
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = taichu
DB_USER = root
DB_PASSWORD = 
DB_CHARSET = utf8mb4
DB_PREFIX = tc_

# JWT配置 - 请使用强密钥，生成命令: openssl rand -base64 32
# 生产环境必须设置此值，且长度不少于32个字符
JWT_SECRET = 
JWT_ISSUER = taichu-api
JWT_AUDIENCE = taichu-app

# 日志配置
LOG_LEVEL = info
LOG_PATH = runtime/log

# API安全配置
API_SIGN_KEY = change-this-key-in-production
REPLAY_PROTECTION_ENABLED = true

# 缓存配置
CACHE_DRIVER = file
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD = 

# 短信服务配置
# 本地测试模式：设置为 true 时，可以使用固定测试验证码
SMS_TEST_MODE = true
# 测试验证码（仅在 SMS_TEST_MODE=true 时有效）
SMS_TEST_CODE = 123456

# 腾讯云短信配置（生产环境使用）
SMS_TENCENT_SECRET_ID = 
SMS_TENCENT_SECRET_KEY = 
SMS_TENCENT_SDK_APP_ID = 
SMS_TENCENT_SIGN_NAME = 
SMS_TENCENT_TEMPLATE_CODE = 

# 微信支付配置
WECHAT_MCH_ID = 
WECHAT_APP_ID = 
WECHAT_API_KEY = 
WECHAT_NOTIFY_URL = 
