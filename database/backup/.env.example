# =====================================================
# 太初命理系统 - 环境配置文件示例
# 复制此文件为 .env 并修改为您的实际配置
# =====================================================

# 应用配置
APP_DEBUG = true
APP_TRACE = false
APP_HOST = 

# 数据库配置
DB_DRIVER = mysql
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = taichu
DB_USER = root
DB_PASSWORD = 
DB_CHARSET = utf8mb4
DB_PREFIX = tc_

# JWT配置（重要：生产环境必须设置强密钥）
# 生成命令: openssl rand -base64 32
JWT_SECRET = 
JWT_ISSUER = taichu-api
JWT_AUDIENCE = taichu-app

# 缓存配置
CACHE_DRIVER = file
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD = 

# 日志配置
LOG_LEVEL = info
LOG_PATH = runtime/log

# API安全配置
API_SIGN_KEY = change-this-key-in-production
REPLAY_PROTECTION_ENABLED = false

# 微信支付配置（可选）
WECHAT_APPID = 
WECHAT_MCHID = 
WECHAT_APIKEY = 
WECHAT_NOTIFY_URL = 

# 腾讯云短信配置（可选）
SMS_PROVIDER = tencent
SMS_APP_ID = 
SMS_SECRET_ID = 
SMS_SECRET_KEY = 
SMS_SIGN_NAME = 
SMS_TEMPLATE_CODE = 
